generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id             String    @id @default(uuid())
  nome           String
  cnpj           String    @unique
  tenant_id      String?
  uaiMerchantId  String?
  configUaiRango Json?
  createdAt      DateTime  @default(now())
  pedidos        Pedido[]
  produtos       Produto[]
  users          User[]
}

model Produto {
  id                  String   @id @default(uuid())
  externalId          String?  @unique
  externalCode        String?
  nome                String
  descricao           String?
  informacaoAdicional String?
  serving             String?
  peso                Float?
  tenant_id           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  empresa             Empresa  @relation(fields: [tenant_id], references: [id])
}

model Pedido {
  id          String            @id @default(uuid())
  uairango_id String            @unique
  displayId   String?
  status      String            @default("RECEIVED")
  valorTotal  Decimal           @default(0.0) @db.Decimal(10, 2)
  subTotal    Decimal           @default(0.0) @db.Decimal(10, 2)
  taxaEntrega Decimal           @default(0.0) @db.Decimal(10, 2)
  clienteNome String?
  clienteDoc  String?
  clienteFone String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant_id   String
  json_bruto  Json?
  empresa     Empresa           @relation(fields: [tenant_id], references: [id])
  historico   PedidoHistorico[]
  itens       PedidoItem[]
  pagamentos  PedidoPagamento[]

  @@index([tenant_id])
}

model PedidoItem {
  id         String             @id @default(uuid())
  pedido_id  String
  externalId String?
  nome       String
  quantidade Int
  precoUnit  Decimal            @db.Decimal(10, 2)
  precoTotal Decimal            @db.Decimal(10, 2)
  obs        String?
  pedido     Pedido             @relation(fields: [pedido_id], references: [id])
  options    PedidoItemOption[]
}

model PedidoItemOption {
  id             String     @id @default(uuid())
  pedido_item_id String
  nome           String
  quantidade     Int
  precoUnit      Decimal    @db.Decimal(10, 2)
  precoTotal     Decimal    @db.Decimal(10, 2)
  pedidoItem     PedidoItem @relation(fields: [pedido_item_id], references: [id])
}

model PedidoPagamento {
  id        String  @id @default(uuid())
  pedido_id String
  metodo    String
  tipo      String
  bandeira  String?
  valor     Decimal @db.Decimal(10, 2)
  prepaid   Boolean @default(false)
  pedido    Pedido  @relation(fields: [pedido_id], references: [id])
}

model PedidoHistorico {
  id        String   @id @default(uuid())
  pedido_id String
  status    String
  createdAt DateTime @default(now())
  pedido    Pedido   @relation(fields: [pedido_id], references: [id])

  @@index([pedido_id])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  active    Boolean  @default(true)
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  

  @@index([empresaId])
  @@map("users")
}

enum PedidoStatus {
  RECEIVED
  CONFIRMED
  DISPATCHED
  READY
  CANCELLED
  PENDING
  SHIPPED
  DELIVERED
  READY_TO_PICKUP
  ORDER_NEW
  PLACED
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}
